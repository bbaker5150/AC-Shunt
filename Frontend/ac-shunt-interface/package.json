{
  "name": "ac-shunt-interface",
  "version": "0.1.0",
  "private": true,
  "main": "public/electron.js",
  "homepage": "./",
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^13.5.0",
    "axios": "1.7.9",
    "bootstrap": "^5.3.7",
    "chart.js": "^4.4.9",
    "chartjs-plugin-zoom": "^2.2.0",
    "concurrently": "^9.2.1",
    "exceljs": "^4.4.0",
    "is-electron": "^2.2.2",
    "react": "^19.1.0",
    "react-bootstrap": "^2.10.10",
    "react-chartjs-2": "^5.3.0",
    "react-dom": "^19.1.0",
    "react-icons": "^5.5.0",
    "react-scripts": "^5.0.1",
    "serve": "^14.2.4",
    "simple-statistics": "^7.8.8",
    "web-vitals": "^2.1.4",
    "xlsx": "^0.18.5"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "electron:dev": "concurrently \"cross-env BROWSER=none npm start\" \"wait-on tcp:3000 && .\\node_modules\\electron\\dist\\electron.exe .\"",
    "electron:build": "npm run build-python && npm run build && electron-builder",
    "build-python": "cd ../../Backend/ac_shunt && pyinstaller ac_shunt_backend.spec --noconfirm"
  },
  "build": {
    "appId": "com.navair.acshunt",
    "productName": "AC Shunt Calibration",
    "files": [
      "build/**/*",
      "public/electron.js"
    ],
    "directories": {
      "buildResources": "public"
    },
    "extraResources": [
      {
        "from": "../../Backend/ac_shunt/dist/ac_shunt_backend",
        "to": "ac_shunt_backend"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "public/favicon.ico"
    }
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "overrides": {
    "nth-check": "^2.0.1",
    "postcss": "^8.4.31"
  },
  "jest": {
    "transformIgnorePatterns": [
      "/node_modules/(?!axios)/"
    ]
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "electron": "^41.2.0",
    "wait-on": "^9.0.5"
  }
}
