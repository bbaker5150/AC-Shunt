{
  "name": "ac-shunt-interface",
  "version": "0.1.0",
  "private": true,
  "main": "public/electron.js",
  "homepage": "./",
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "axios": "1.7.9",
    "axios-retry": "^4.5.0",
    "bootstrap": "^5.3.7",
    "chart.js": "^4.4.9",
    "chartjs-plugin-zoom": "^2.2.0",
    "exceljs": "^4.4.0",
    "gsap": "^3.15.0",
    "katex": "^0.16.45",
    "react": "^19.1.0",
    "react-chartjs-2": "^5.3.0",
    "react-dom": "^19.1.0",
    "react-icons": "^5.5.0",
    "react-katex": "^3.1.0",
    "simple-statistics": "^7.8.8",
    "xlsx": "^0.18.5"
  },
  "scripts": {
    "start": "vite --host 0.0.0.0 --port 3000",
    "build": "vite build",
    "preview": "vite preview --port 3000",
    "test": "vitest run",
    "test:watch": "vitest",
    "start:backend": "cd ../../Backend/ac_shunt && ..\\..\\venv\\Scripts\\python.exe manage.py bootstrap && ..\\..\\venv\\Scripts\\python.exe manage.py runserver 0.0.0.0:8000",
    "dev": "concurrently \"npm run start:backend\" \"npm start\"",
    "dev:mock": "cross-env MOCK_INSTRUMENTS=1 concurrently \"npm run start:backend\" \"npm start\"",
    "electron:dev": "concurrently \"npm run start:backend\" \"cross-env BROWSER=none npm start\" \"wait-on tcp:3000 tcp:8000 && .\\node_modules\\electron\\dist\\electron.exe .\"",
    "electron:dev:mock": "cross-env MOCK_INSTRUMENTS=1 concurrently \"npm run start:backend\" \"cross-env BROWSER=none npm start\" \"wait-on tcp:3000 tcp:8000 && .\\node_modules\\electron\\dist\\electron.exe .\"",
    "seed-mock": "cd ../../Backend/ac_shunt && ..\\..\\venv\\Scripts\\python.exe manage.py seed_mock_calibration_session",
    "serve:build": "concurrently \"npm run start:backend\" \"serve -s build -l 3000\"",
    "electron:build": "npm run build-python && npm run build && electron-builder",
    "build-python": "cd ../../Backend/ac_shunt && pyinstaller ac_shunt_backend.spec --noconfirm"
  },
  "build": {
    "appId": "com.navair.acshunt",
    "productName": "AC Shunt Calibration",
    "files": [
      "build/**/*",
      "public/electron.js"
    ],
    "directories": {
      "buildResources": "public"
    },
    "extraResources": [
      {
        "from": "../../Backend/ac_shunt/dist/ac_shunt_backend",
        "to": "ac_shunt_backend"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "public/favicon.ico"
    }
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^13.5.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.2.0",
    "electron-builder": "^26.0.12",
    "jsdom": "^25.0.1",
    "serve": "^14.2.6",
    "vite": "^6.0.7",
    "vitest": "^2.1.8",
    "wait-on": "^9.0.5"
  }
}
